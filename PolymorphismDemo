public class PolymorphismDemo {
    public static void main(String[] args) {
        Person[] people = new Person[3];
        
        people[0] = new Person("Alice", 25);
        people[1] = new Student("Bob", 19, "Hoboken High School");
        people[2] = new Employee("Charlie", 35, 60000);
        
        for (Person p : people) {
            p.introduce();
            System.out.println();
        }
    }
}
